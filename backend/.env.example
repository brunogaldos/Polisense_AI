# Firebase
FIREBASE_PROJECT_ID=elliptical-feat-498811-c6
# Either provide a key file:
GOOGLE_APPLICATION_CREDENTIALS=google_serviceAccountKey.json
# Or inline credentials:
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json 
# LLM provider: openai (default) | gemini | openrouter | local
AI_PROVIDER=gemini
# Generation provider — can differ from AI_PROVIDER (same options)
RAG_GENERATION=gemini

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=
AI_MODEL_NAME=gpt-4o-mini
EXTRACTION_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Gemini / Vertex AI (used when AI_PROVIDER=gemini)
# Set GOOGLE_APPLICATION_CREDENTIALS above to the service account JSON path
GEMINI_SERVICE_ACCOUNT_KEY=google_serviceAccountKey.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# ROUTER_MODEL — routing/classification model (overrides provider default)
ROUTER_MODEL=google/gemini-2.5-flash
# GEMINI_CHAT_MODEL — generation model (default: google/gemini-2.0-flash-001)
GEMINI_CHAT_MODEL=google/gemini-2.5-flash

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Server
PORT=5029
API_BASE_PATH=/api/policy_research

# Optional overrides
# DATA_LAYOUT_PATH=
# MCP_SERVICE_DIR=
# PYTHON_EXECUTABLE=
# MULTIMODAL_MAX_ATTACHED_FILES=4
# MULTIMODAL_MAX_ATTACHED_BYTES=12582912
